{
  "permissions": {
    "allow": [
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run lint*)",
      "Bash(npm test*)",
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(npm run db:push*)",
      "Bash(npm run db:migrate*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(curl * | sh)"
    ]
  }
}
