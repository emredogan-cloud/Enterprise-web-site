# =============================================================================
# Digital Bookstore — Environment Variables Template
# =============================================================================
# Copy to `.env.local` for local development. NEVER commit real secrets.
#
# IMPORTANT — Vercel environments
# Every variable below must be configured separately for **each** Vercel
# environment: Preview, Staging, and Production
# (Vercel dashboard → Settings → Environment Variables, or `vercel env add`).
# Use isolated credentials per environment:
#   • a unique database (Neon branch / Supabase project) per env
#   • a unique R2 bucket pair (masters + artifacts) per env
#   • MoR sandbox keys for Preview/Staging, live keys only in Production
# (Roadmap §12 — "Separate buckets, DB branches, and MoR sandbox keys per environment.")
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public base URL of THIS deployment. Used for absolute links, OG tags,
# and the webhook callback URLs you register with the MoR / Auth provider.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Database — PostgreSQL (Neon or Supabase, per Roadmap §10 / PAST_DECISIONS)
# -----------------------------------------------------------------------------
# Pooled connection string used by the running app (PgBouncer / pooler endpoint).
#   Neon example:     postgresql://USER:PASSWORD@<host>-pooler.<region>.aws.neon.tech/DB?sslmode=require
#   Supabase example: postgresql://postgres.<ref>:PASSWORD@<host>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Direct (non-pooled) connection string used by migrations and long-running
# transactions (Prisma `migrate`, Drizzle). Required by both Neon and Supabase.
DIRECT_URL=


# -----------------------------------------------------------------------------
# Authentication — Clerk (preferred per ADR-8) OR Auth.js (NextAuth v5)
# Use EITHER block, not both. SUB-PR 0.5 commits to one.
# -----------------------------------------------------------------------------
# --- Option A: Clerk (managed; magic-link + social; fastest path) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=

# --- Option B: Auth.js (NextAuth v5; self-hosted; portable) ---
# AUTH_SECRET=                        # generate with `npx auth secret`
# AUTH_URL=                           # canonical URL, e.g. https://www.your-domain.com
# AUTH_RESEND_KEY=                    # magic-link via Resend
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=


# -----------------------------------------------------------------------------
# Merchant of Record (MoR) — Paddle OR Lemon Squeezy (Roadmap ADR-2)
# Use EITHER block. SUB-PR 1.5 commits to one.
# Webhook secrets are mandatory: every webhook must be signature-verified
# (Roadmap §11 — "idempotent webhooks with signature verification").
# -----------------------------------------------------------------------------
# --- Option A: Paddle ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox            # sandbox | production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=      # exposed to the client checkout

# --- Option B: Lemon Squeezy ---
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Object Storage — Cloudflare R2 (Roadmap ADR-6, zero-egress)
# TWO private buckets per environment: source masters + per-order
# watermarked artifacts (Roadmap §9 architecture diagram).
# Use a unique bucket pair for Preview / Staging / Production.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=                          # e.g. https://<account>.r2.cloudflarestorage.com
R2_BUCKET_MASTERS=bookstore-masters-dev        # private — uploaded source PDFs (never public)
R2_BUCKET_ARTIFACTS=bookstore-artifacts-dev    # private — per-order watermarked PDFs
# Optional custom CDN domain in front of the artifacts bucket. Leave blank to
# serve via signed URLs against R2_ENDPOINT directly (default).
R2_PUBLIC_BASE_URL=


# -----------------------------------------------------------------------------
# Async Jobs — Inngest (preferred per Roadmap §9) OR Vercel Queues (native)
# Drives the watermarking pipeline (Roadmap ADR-3).
# -----------------------------------------------------------------------------
# --- Option A: Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Option B: Vercel Queues ---
# When using Vercel Queues, no manual env vars are required — the runtime
# injects connection details once the queue is provisioned in the project.


# -----------------------------------------------------------------------------
# Transactional Email — Resend (preferred) or Postmark (Roadmap §9)
# Used for "your book is ready", receipts, and (with Auth.js) magic links.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Digital Bookstore <noreply@your-domain.com>


# -----------------------------------------------------------------------------
# Observability — Sentry (Roadmap §12)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                    # only required for source-map upload at build
SENTRY_ORG=
SENTRY_PROJECT=
